  <property name="styleSheet">
   <string notr="true">*{
	background-color: #dfdfdf;
	font: 600 9pt &quot;Segoe UI&quot;;
	color: #324b4c;
}

QScrollBar:vertical {
	width: 20px;
	background: none;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
	background: #dfdfdf;
}

QPushButton {
	background-color: #c9c9c9;
	border: none;
	border-radius: 10px;
	padding: 5px;
	font-size: 9pt;
}

QPushButton:hover{
	background-color: #aeaeae;
}

QDateEdit::up-button, QDateEdit::down-button{
	width: 0px;
}

QLineEdit, QDateEdit{
	border: none;
	font-size: 9pt;
	border-bottom: 1px solid #7c9399;
}

QMenu {
	border: 1px solid #aeaeae;
	border-radius: 5px;
}

QMenu::item {
	padding: 5px;
	font-size: 8pt;
}

QMenu::item:selected {
	background-color: #aeaeae;
	padding-left: 7px;
}

QComboBox{
	background-color: #dfdfdf;
	border-bottom: 2px solid #7c9399;
	border-radius: 3px;
}

QComboBox::drop-down{
	image: url(':/icons/app/assets/icons/Alt-Arrow-Down--Streamline-Solar-Broken.svg');
	width: 16px;
	height: 16px;
}

QComboBox:hover{
	color: #2b2b2c;
	font: 700 9pt &quot;Segoe UI&quot;;
	border-radius: 0px;
	alternate-background-color: #2c313c;
}
QComboBox::item:selected{
	color: #2b2b2c;
	font: 700 9pt &quot;Segoe UI&quot;;
	border-radius: 0px;
}
QComboBox::item{
	color: #324b4c;
	font: 600 9pt &quot;Segoe UI&quot;;
	height: 10px;  
	border: 4px solid transparent;
	padding: 0px 4px 0px 4px;
}

#modelHolder QLabel, #newModelInfoHolder * , #widget_11 *{
	font-size: 9pt;
}

#optionsHolder, #optionsHolder_2 {
	border-bottom: 2px dashed #7c9399;
}

#pageTitle {
	font: 700 11pt &quot;Segoe UI&quot;;
}

#userIcon, #logoutBtn, #fromCalendarBtn, #fromCalendarBtn_2, #toCalendarBtn, #toCalendarBtn_2 {
	background-color: #dfdfdf;
	padding: 0px;
}

#logoutBtn:hover{
	icon: url(:/icons/app/assets/icons/Log-Out--Streamline-Feather_#192626.svg);
}


#usernameLabel {
	font-size: 10pt;
}

#workerPlaceLineEdit, #workerPositionLineEdit {
	font-weight: 600;
}

#widget_3 * {
	font-size: 9pt;
}</string>
