  <property name="styleSheet">
   <string notr="true">*{
	background-color: #dfdfdf;
	font: 600 9pt &quot;Segoe UI&quot;;
	color: #324b4c;
}

QPushButton {
	background-color: #c9c9c9;
	border: none;
	border-radius: 10px;
	padding: 5px;
	font-size: 8pt;
}

QPushButton:hover{
	background-color: #aeaeae;
}

#operationsHolder QCheckBox:checked, #modelHolder QCheckBox:checked{
	color: #008b69;
}

QLineEdit {
	border: none;
	font-size: 8pt;
	border-bottom: 1px solid #7c9399;
}

#modelHolder QLabel, #newModelInfoHolder *, #operationsGroupsHolder *, #widget_3 * {
	font-size: 8pt;
}

#modelLabel {
	font-size: 10pt;
	font-weight: 700;
}

#widget_4 *, #saveOpertaionsGroupsBtn, #saveNewModel, #deleteOperetionGroupsBtn {
	font-size: 8pt;
	font-weight: 700;
}

#modelNameLabel {
	font-weight: 700;
}

#optionsHolder {
	border-bottom: 2px dashed #7c9399;
}

#pageTitle {
	font: 700 11pt &quot;Segoe UI&quot;;
}

#userIcon, #logoutBtn {
	background-color: #dfdfdf;
	padding: 0px;
}

#logoutBtn:hover{
	icon: url(:/icons/app/assets/icons/Log-Out--Streamline-Feather_#192626.svg);
}

#deleteModelBtn, #oldModelsBtn {
	background-color: #dfdfdf;
	padding: 2px;
}

#deleteModelBtn:hover, #oldModelsBtn:hover{
	background-color: #aeaeae;
}

#usernameLabel {
	font-size: 10pt;
}

#modelWorkPlacesBtn {
	padding: 3px;
}

QMenu {
	border: 1px solid #aeaeae;
	border-radius: 5px;
}

QMenu::item {
	padding: 5px;
	font-size: 8pt;
}

QMenu::item:disabled {
	color: #8e9090;
}

QMenu::item:selected {
	background-color: #aeaeae;
	padding-left: 7px;
}

QComboBox{
	background-color: #dfdfdf;
	border-bottom: 2px solid #7c9399;
	border-radius: 3px;
}

QComboBox::drop-down{
	image: url(':/icons/app/assets/icons/Alt-Arrow-Down--Streamline-Solar-Broken.svg');
	width: 16px;
	height: 16px;
}

QComboBox:hover{
	color: #2b2b2c;
	font: 700 8pt &quot;Segoe UI&quot;;
	border-radius: 0px;
	alternate-background-color: #2c313c;
}
QComboBox::item:selected{
	color: #2b2b2c;
	font: 700 8pt &quot;Segoe UI&quot;;
	border-radius: 0px;
}
QComboBox::item{
	color: #324b4c;
	font: 600 8pt &quot;Segoe UI&quot;;
	height: 10px;  
	border: 4px solid transparent;
	padding: 0px 4px 0px 4px;
}</string>
